# Application Settings
APP_NAME=Hunyuan3D-2 Web API
DEBUG=false
VERSION=1.0.0

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/hunyuan3d

# Redis
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
ALLOWED_HOSTS=["http://localhost:3000", "http://127.0.0.1:3000"]

# Hunyuan3D-2 Settings
HUNYUAN_MODEL_PATH=tencent/Hunyuan3D-2
HUNYUAN_SUBFOLDER=hunyuan3d-dit-v2-0
TEXGEN_MODEL_PATH=tencent/Hunyuan3D-2
LOW_VRAM_MODE=true
ENABLE_FLASHVDM=false

# AI Settings
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4

# File Storage
UPLOAD_DIR=uploads
MODELS_DIR=models
MAX_FILE_SIZE=10485760

# GPU Settings
CUDA_VISIBLE_DEVICES=0
TORCH_CUDA_ARCH_LIST=

# Background Tasks
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
